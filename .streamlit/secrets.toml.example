# Copiá este archivo a secrets.toml y completá con tu JSON de cuenta de servicio de Google.
# En la consola de Google Cloud: IAM → Cuentas de servicio → Claves → JSON
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# El bloque [gcp_service_account] debe coincidir con las claves del archivo .json descargado.

[gcp_service_account]
type = "service_account"
project_id = "tu-proyecto-id"
private_key_id = "xxxxxxxx"
private_key = """-----BEGIN PRIVATE KEY-----
REEMPLAZAR_CON_LA_CLAVE_COMPLETA_DEL_JSON
-----END PRIVATE KEY-----
"""
client_email = "tu-cuenta@tu-proyecto.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
